# Local development — copy to .env.local
# Vercel deploy — add these in Vercel Environment Variables

# Neon PostgreSQL (REQUIRED)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Customer auth session (REQUIRED — min 32 chars)
CUSTOMER_SESSION_SECRET=your-long-random-secret-min-32-chars

# Admin Portal (REQUIRED)
ADMIN_USERNAME=ShOeMafia
ADMIN_PASSWORD="ShoeMAFia@#1"
ADMIN_SESSION_SECRET=your-long-random-secret-min-32-chars

# App URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_STORE_NAME=SHOE MAFIA
NEXT_PUBLIC_STORE_PHONE=07587555558

# Razorpay (optional — online payments)
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email (optional)
RESEND_API_KEY=
EMAIL_FROM=orders@shoemafia.in
ADMIN_EMAIL=admin@shoemafia.in

# Cron (optional)
CRON_SECRET=your-cron-secret
